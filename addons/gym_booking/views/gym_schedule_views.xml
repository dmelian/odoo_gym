<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- Vista lista -->
    <record id="view_gym_schedule_list" model="ir.ui.view">
        <field name="name">gym.schedule.list</field>
        <field name="model">gym.schedule</field>
        <field name="arch" type="xml">
            <list string="Horarios">
                <field name="activity_id"/>
                <field name="day_of_week"/>
                <field name="time_start" widget="float_time"/>
                <field name="time_end" widget="float_time"/>
                <field name="capacity"/>
                <field name="active"/>
            </list>
        </field>
    </record>

    <!-- Vista formulario -->
    <record id="view_gym_schedule_form" model="ir.ui.view">
        <field name="name">gym.schedule.form</field>
        <field name="model">gym.schedule</field>
        <field name="arch" type="xml">
            <form string="Horario">
                <sheet>
                    <div class="oe_title">
                        <h1>
                            <field name="activity_id" placeholder="Actividad"/>
                        </h1>
                    </div>
                    <group>
                        <group string="Horario">
                            <field name="day_of_week"/>
                            <field name="time_start" widget="float_time"/>
                            <field name="time_end" widget="float_time"/>
                        </group>
                        <group string="Capacidad">
                            <field name="capacity"/>
                            <field name="active"/>
                        </group>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <!-- Vista búsqueda -->
    <record id="view_gym_schedule_search" model="ir.ui.view">
        <field name="name">gym.schedule.search</field>
        <field name="model">gym.schedule</field>
        <field name="arch" type="xml">
            <search string="Buscar horarios">
                <field name="activity_id"/>
                <field name="day_of_week"/>
                <filter name="monday" string="Lunes" domain="[('day_of_week', '=', '0')]"/>
                <filter name="tuesday" string="Martes" domain="[('day_of_week', '=', '1')]"/>
                <filter name="wednesday" string="Miércoles" domain="[('day_of_week', '=', '2')]"/>
                <filter name="thursday" string="Jueves" domain="[('day_of_week', '=', '3')]"/>
                <filter name="friday" string="Viernes" domain="[('day_of_week', '=', '4')]"/>
                <filter name="saturday" string="Sábado" domain="[('day_of_week', '=', '5')]"/>
                <filter name="sunday" string="Domingo" domain="[('day_of_week', '=', '6')]"/>
                <separator/>
                <filter name="active" string="Activos" domain="[('active', '=', True)]"/>
                <filter name="inactive" string="Archivados" domain="[('active', '=', False)]"/>
                <group expand="0" string="Agrupar por">
                    <filter name="group_activity" string="Actividad" context="{'group_by': 'activity_id'}"/>
                    <filter name="group_day" string="Día" context="{'group_by': 'day_of_week'}"/>
                </group>
            </search>
        </field>
    </record>

    <!-- Acción -->
    <record id="action_gym_schedule" model="ir.actions.act_window">
        <field name="name">Horarios</field>
        <field name="res_model">gym.schedule</field>
        <field name="view_mode">list,form</field>
        <field name="search_view_id" ref="view_gym_schedule_search"/>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Crea el primer horario semanal
            </p>
        </field>
    </record>

</odoo>