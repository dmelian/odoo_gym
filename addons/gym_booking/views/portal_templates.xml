<odoo>

    <!-- 1. Tarjeta en /my/home -->
    <template id="portal_my_home_gym" inherit_id="portal.portal_my_home" priority="30">
        <xpath expr="//div[@id='portal_common_category']" position="before">
            <div class="o_portal_category row g-2 mt-3" id="portal_gym_category">
                <div class="o_portal_index_card col-md-6 order-2">
                    <a href="/my/gym" title="Mi Gimnasio"
                      class="d-flex gap-2 gap-md-3 py-3 pe-2 px-md-3 h-100 rounded text-decoration-none bg-100">
                        <div class="o_portal_icon d-block align-self-start">
                            <img src="/gym_booking/static/src/img/gym.svg"/>
                        </div>
                        <div>
                            <div class="mt-0 mb-1 fs-5 fw-normal lh-1">
                                <span>Mi Gimnasio</span>
                            </div>
                            <div class="opacity-75">
                                Gestiona tus reservas y sesiones semanales
                            </div>
                        </div>
                    </a>
                </div>
            </div>
        </xpath>
    </template>

    <!-- 2. Página /my/gym -->
    <template id="portal_gym_home" name="Gym - Mi Gimnasio">
        <t t-call="portal.portal_layout">
            <div class="container mt-4">

                <t t-if="member">
                    <h2>Hola, <t t-esc="member.name"/> 👋</h2>
                    <p>Bienvenido a tu área de socio.</p>
                    <div class="row mt-4">
                        <div class="col-md-6 mb-3">
                            <a href="/my/gym/schedule" class="btn btn-primary w-100">
                                📅 Ver horarios
                            </a>
                        </div>
                        <div class="col-md-6 mb-3">
                            <a href="/my/gym/bookings" class="btn btn-secondary w-100">
                                📋 Mis reservas
                            </a>
                        </div>
                    </div>
                </t>

                <t t-else="">
                    <div class="alert alert-warning">
                        No se encontró ningún socio vinculado a tu usuario.
                    </div>
                </t>

            </div>
        </t>
    </template>

  <!-- 3. Página /my/gym/schedule -->
  <template id="portal_gym_schedule" name="Gym - Horarios Semanales">
      <t t-call="portal.portal_layout">
          <div class="container mt-4">
              <div class="d-flex justify-content-between align-items-center mb-3">
                  <h2>📅 Horarios semanales</h2>
                  <a href="/my/gym" class="btn btn-outline-secondary btn-sm">← Volver</a>
              </div>

              <t t-if="member">
                  <div class="mb-3">
                      <span class="badge bg-success me-2">■</span><small>Actividades en las que estás inscrito</small>
                      <span class="badge bg-secondary ms-3 me-2">■</span><small>Otras actividades disponibles</small>
                  </div>

                  <div class="table-responsive">
                      <table class="table table-bordered text-center align-middle">
                          <thead class="table-dark">
                              <tr>
                                  <th style="width:90px;">Hora</th>
                                  <t t-foreach="days" t-as="day">
                                      <th><t t-esc="day[1]"/></th>
                                  </t>
                              </tr>
                          </thead>
                          <tbody>
                              <t t-foreach="slots" t-as="slot">
                                  <tr>
                                      <!-- Columna hora -->
                                      <td class="fw-bold text-muted">
                                          <t t-esc="'%02d:00' % int(slot)"/>
                                      </td>
                                      <!-- Columna por día -->
                                      <t t-foreach="days" t-as="day">
                                          <t t-set="cell" t-value="grid[slot][day[0]]"/>
                                          <td>
                                              <t t-if="cell">
                                                  <span t-attf-class="badge w-100 py-2 {{ 'bg-success' if cell['subscribed'] else 'bg-secondary' }}">
                                                      <t t-esc="cell['schedule'].activity_id.name"/>
                                                  </span>
                                              </t>
                                          </td>
                                      </t>
                                  </tr>
                              </t>
                          </tbody>
                      </table>
                  </div>
              </t>
              <t t-else="">
                  <div class="alert alert-warning">
                      No se encontró ningún socio vinculado a tu usuario.
                  </div>
              </t>
          </div>
      </t>
  </template>



</odoo>