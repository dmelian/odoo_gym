<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- Vista lista -->
    <record id="view_gym_booking_batch_list" model="ir.ui.view">
        <field name="name">gym.booking.batch.list</field>
        <field name="model">gym.booking.batch</field>
        <field name="arch" type="xml">
            <list string="Lotes" create="false" edit="false" delete="false">
                <field name="name"/>
                <field name="date"/>
                <field name="user_id"/>
                <field name="origin" widget="badge"
                       decoration-info="origin == 'manual'"
                       decoration-success="origin == 'automatic'"/>
                <field name="bookings_created"/>
                <field name="bookings_skipped"/>
            </list>
        </field>
    </record>

    <!-- Vista formulario -->
    <record id="view_gym_booking_batch_form" model="ir.ui.view">
        <field name="name">gym.booking.batch.form</field>
        <field name="model">gym.booking.batch</field>
        <field name="arch" type="xml">
            <form string="Lote de reservas" create="false" edit="false">
                <sheet>
                    <div class="oe_title">
                        <h1>
                            <field name="name" readonly="1"/>
                        </h1>
                    </div>
                    <group>
                        <group string="Información">
                            <field name="date" readonly="1"/>
                            <field name="user_id" readonly="1"/>
                            <field name="origin" readonly="1"/>
                        </group>
                        <group string="Resultado">
                            <field name="bookings_created" readonly="1"/>
                            <field name="bookings_skipped" readonly="1"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Reservas generadas" name="bookings">
                            <field name="booking_ids">
                                <list>
                                    <field name="name"/>
                                    <field name="member_id"/>
                                    <field name="activity_id"/>
                                    <field name="date"/>
                                    <field name="time_start" widget="float_time"/>
                                    <field name="state"/>
                                </list>
                            </field>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <!-- Acción -->
    <record id="action_gym_booking_batch" model="ir.actions.act_window">
        <field name="name">Historial de lotes</field>
        <field name="res_model">gym.booking.batch</field>
        <field name="view_mode">list,form</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Aún no se ha generado ningún lote de reservas
            </p>
        </field>
    </record>

</odoo>