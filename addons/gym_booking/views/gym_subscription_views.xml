<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- Vista lista -->
    <record id="view_gym_subscription_list" model="ir.ui.view">
        <field name="name">gym.subscription.list</field>
        <field name="model">gym.subscription.line</field>
        <field name="arch" type="xml">
            <list string="Suscripciones">
                <field name="member_id"/>
                <field name="activity_id"/>
                <field name="schedule_id"/>
                <field name="day_of_week"/>
                <field name="time_start" widget="float_time"/>
                <field name="active"/>
            </list>
        </field>
    </record>

    <!-- Vista formulario -->
    <record id="view_gym_subscription_form" model="ir.ui.view">
        <field name="name">gym.subscription.form</field>
        <field name="model">gym.subscription.line</field>
        <field name="arch" type="xml">
            <form string="Suscripción">
                <sheet>
                    <div class="oe_title">
                        <h1>
                            <field name="member_id" placeholder="Abonado"/>
                        </h1>
                    </div>
                    <group>
                        <group string="Sesión">
                            <field name="activity_id"/>
                            <field name="schedule_id"
                                   domain="[('activity_id', '=', activity_id)]"/>
                            <field name="day_of_week" readonly="1"/>
                            <field name="time_start" widget="float_time" readonly="1"/>
                            <field name="active"/>
                        </group>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <!-- Vista búsqueda -->
    <record id="view_gym_subscription_search" model="ir.ui.view">
        <field name="name">gym.subscription.search</field>
        <field name="model">gym.subscription.line</field>
        <field name="arch" type="xml">
            <search string="Buscar suscripciones">
                <field name="member_id"/>
                <field name="activity_id"/>
                <filter name="active" string="Activas"
                        domain="[('active', '=', True)]"/>
                <filter name="inactive" string="Inactivas"
                        domain="[('active', '=', False)]"/>
                <separator/>
                <filter name="monday" string="Lunes"
                        domain="[('day_of_week', '=', '0')]"/>
                <filter name="tuesday" string="Martes"
                        domain="[('day_of_week', '=', '1')]"/>
                <filter name="wednesday" string="Miércoles"
                        domain="[('day_of_week', '=', '2')]"/>
                <filter name="thursday" string="Jueves"
                        domain="[('day_of_week', '=', '3')]"/>
                <filter name="friday" string="Viernes"
                        domain="[('day_of_week', '=', '4')]"/>
                <filter name="saturday" string="Sábado"
                        domain="[('day_of_week', '=', '5')]"/>
                <filter name="sunday" string="Domingo"
                        domain="[('day_of_week', '=', '6')]"/>
                <separator/>
                <group expand="0" string="Agrupar por">
                    <filter name="group_member" string="Abonado"
                            context="{'group_by': 'member_id'}"/>
                    <filter name="group_activity" string="Actividad"
                            context="{'group_by': 'activity_id'}"/>
                    <filter name="group_day" string="Día"
                            context="{'group_by': 'day_of_week'}"/>
                </group>
            </search>
        </field>
    </record>

    <!-- Acción -->
    <record id="action_gym_subscription" model="ir.actions.act_window">
        <field name="name">Suscripciones</field>
        <field name="res_model">gym.subscription.line</field>
        <field name="view_mode">list,form</field>
        <field name="search_view_id" ref="view_gym_subscription_search"/>
        <field name="context">{'search_default_active': 1}</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Crea la primera suscripción semanal
            </p>
        </field>
    </record>

</odoo>
