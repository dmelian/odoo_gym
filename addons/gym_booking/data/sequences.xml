<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">

        <record id="seq_gym_booking" model="ir.sequence">
            <field name="name">Reserva Gimnasio</field>
            <field name="code">gym.booking</field>
            <field name="prefix">GYM/%(year)s/</field>
            <field name="padding">4</field>
            <field name="company_id" eval="False"/>
        </record>

        <record id="seq_gym_booking_batch" model="ir.sequence">
            <field name="name">Lote de Reservas</field>
            <field name="code">gym.booking.batch</field>
            <field name="prefix">BAT/%(year)s/</field>
            <field name="padding">4</field>
            <field name="company_id" eval="False"/>
        </record>

    </data>
</odoo>